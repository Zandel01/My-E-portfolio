rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /portfolios/{portfolioId} {
      // Allow anyone to read a portfolio by its ID
      allow get: if true;
      
      // Allow anyone to create a new portfolio snapshot
      // We use create instead of write to prevent overwriting existing portfolios
      allow create: if request.resource.data.keys().hasAll(['compressedData', 'createdAt'])
                   && request.resource.data.compressedData is string
                   && request.resource.data.compressedData.size() < 1048576; // 1MB limit for Firestore docs
      
      // Do not allow listing all portfolios
      allow list: if false;
      
      // Do not allow updating or deleting once created
      allow update, delete: if false;
    }
  }
}
